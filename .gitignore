# Segredos e configuração local
.env
.env.*
!.env.example
*.key
*.pem

# Cache Python
__pycache__/
*.pyc
*.pyo
*.pyd
*.egg-info/
.pytest_cache/

# Virtualenvs (apenas em uso local — Colab não usa)
.venv/
venv/
env/

# Notebooks Jupyter
.ipynb_checkpoints/

# Caches de embeddings/HF (regeneráveis, podem chegar a 1+ GB)
.cache/
sentence_transformers/

# Logs estruturados
logs/*.json
logs/*.log
logs/*.jsonl

# Banco de dados vetorial (regenerável)
chroma_db/
.chroma/

# Sistema operacional
.DS_Store
Thumbs.db

# IDE
.vscode/
.idea/
*.swp

# Pasta de referência dos patches — não versionar
_ref_bluadiagnostics/

# Backups da aplicacao da Sprint 2 (locais, nao versionar)
_backup_sprint2/

# Agendamentos persistidos pelo agendar_teleconsulta
# (dado dinâmico — apenas estrutura é versionada via .gitkeep)
data/consultas/*
!data/consultas/.gitkeep

# Pasta temporária de mocks (fonte original — já integrada em
# data/mocks/ e dashboard/data/). Não versionar pra não duplicar.
pacientes_csv/

# Backups locais (ex: perfis_clinicos.json.bak_2pacientes)
*.bak
*.bak_*

# data/runtime/ NAO esta mais gitignored — anotacoes_demo.json e
# rascunhos_demo.json sao seeds da demo (banca precisa ver ao clonar).
# Se demo gerar diff (medico aprovando/editando), 'git checkout -- data/runtime/'
# antes da proxima apresentacao volta ao estado inicial.
