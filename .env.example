# BluaDiagnostics — variáveis de ambiente (Sprint 2)
#
# Copie este arquivo para .env e preencha os valores.
# NUNCA commitar .env para o Git (.gitignore já bloqueia).

# ----------------------------------------------------------------
# Backend LLM: 'dashscope' (cloud, default) ou 'ollama' (local)
# ----------------------------------------------------------------
LLM_BACKEND=dashscope

# ----------------------------------------------------------------
# DashScope International (modo cloud)
# Obtenha em: https://dashscope-intl.console.alibabacloud.com
# Free tier: $10 de boas-vindas — suficiente para Sprint 2
# ----------------------------------------------------------------
DASHSCOPE_API_KEY=your_dashscope_key_here
# qwen-turbo: ~30% mais rápido que qwen-plus, qualidade aceitável pra demo.
QWEN_DASHSCOPE_MODEL=qwen-turbo

# ----------------------------------------------------------------
# Ollama (modo local, narrativa LGPD)
# Requer Ollama >= 0.3.0 para function calling
# Instalar: https://ollama.com  →  ollama pull qwen2.5:14b
# ----------------------------------------------------------------
QWEN_OLLAMA_MODEL=qwen2.5:14b
OLLAMA_BASE_URL=http://localhost:11434

# ----------------------------------------------------------------
# LangSmith — observabilidade (opcional, BÔNUS Sprint 2)
# Free tier: 5000 traces/mês
# Obtenha em: https://smith.langchain.com
# ----------------------------------------------------------------
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=BluaDiagnostics-Sprint2

# ----------------------------------------------------------------
# ChromaDB — diretório de persistência
# ----------------------------------------------------------------
CHROMA_PERSIST_DIR=./chroma_db

# ----------------------------------------------------------------
# Performance / demo (lote 1 TURBO)
# ----------------------------------------------------------------
# Safety auditor LLM (camada 2): "enabled" (produção) ou "disabled" (demo,
# -1 a -2s por turno quando dispara). Camada 1 heurística continua ativa.
BLUA_SAFETY_AUDITOR=enabled

# ----------------------------------------------------------------
# Alertas por e-mail do /monitor (opt-in, default desabilitado)
# ----------------------------------------------------------------
# Só envia se BLUA_EMAIL_ALERTS=enabled E as 3 vars abaixo preenchidas.
BLUA_EMAIL_ALERTS=disabled
EMAIL_REMETENTE=
SENHA_REMETENTE=
EMAIL_DESTINATARIO_1=
